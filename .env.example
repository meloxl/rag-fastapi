DOCS_DIR=docs
CHROMA_DIR=chroma_db
RETRIEVE_K=3
LLM_TEMPERATURE=0
RAG_PROVIDER=local

# ---------- 向量化（二选一）----------
# 本地 Ollama
EMBED_PROVIDER=ollama
EMBED_MODEL_ID=nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434

# 硅基流动 / 其他 OpenAI 兼容 Embedding API（示例）
# EMBED_PROVIDER=openai_compatible
# EMBED_MODEL_ID=Qwen/Qwen3-Embedding-8B
# OPENAI_COMPATIBLE_API_BASE=https://api.siliconflow.cn/v1
# OPENAI_COMPATIBLE_API_KEY=your-api-key-here
# 别名（与上面等价）：SILICONFLOW_API_KEY、SILICONFLOW_API_BASE

# ---------- 生成模型（硅基流动 / OpenAI 兼容 Chat API）----------
LLM_MODEL=Qwen/Qwen3-VL-8B-Instruct
# 默认会复用 OPENAI_COMPATIBLE_API_BASE / OPENAI_COMPATIBLE_API_KEY
# 也可以单独配置：
# LLM_API_BASE=https://api.siliconflow.cn/v1
# LLM_API_KEY=your-api-key-here
# 别名（与上面等价）：SILICONFLOW_LLM_API_KEY、SILICONFLOW_LLM_BASE_URL

# ---------- RAG 后端：阿里云百炼应用 / 云知识库 ----------
# RAG_PROVIDER=bailian
# BAILIAN_APP_ID=w6gsdtpq67
# BAILIAN_WORKSPACE_ID=ws-kjehcatf1uzce0xp
# BAILIAN_API_KEY=your-dashscope-api-key-here
# BAILIAN_API_BASE=https://dashscope.aliyuncs.com/api/v1
# BAILIAN_TIMEOUT=60
